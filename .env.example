# ── Newsletter / lead capture (Resend) ──────────────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Audience (list) ID from https://resend.com/audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Random secret used to sign double-opt-in tokens (e.g. `openssl rand -hex 32`)
NEWSLETTER_SECRET=replace-with-a-long-random-string
# Verified sender on your domain (set up SPF/DKIM/DMARC in Resend first)
NEWSLETTER_FROM=Nucleo Longevity <ciao@nucleolongevity.com>
# OPTIONAL — your inbox: get an email every time a new lead confirms
NEWSLETTER_NOTIFY=lorenzogennai99@gmail.com
